{
  "name": "@asterin/minicpa",
  "version": "0.0.1",
  "description": "Thin cpa CLI: layout, lifecycle, and updates for CLIProxyAPI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cpa": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
