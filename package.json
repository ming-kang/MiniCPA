{
  "name": "@astralyn/minicpa",
  "version": "0.0.5",
  "description": "Thin cpa CLI: layout, lifecycle, and updates for CLIProxyAPI",
  "license": "MIT",
  "author": "ming-kang",
  "type": "module",
  "bin": {
    "cpa": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && node --import tsx --test src/**/*.test.ts",
    "prepublishOnly": "npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ming-kang/MiniCPA.git"
  },
  "homepage": "https://github.com/ming-kang/MiniCPA#readme",
  "bugs": {
    "url": "https://github.com/ming-kang/MiniCPA/issues"
  },
  "keywords": [
    "cli",
    "cpa",
    "cliproxyapi",
    "cli-proxy-api",
    "proxy",
    "management",
    "update"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^13.1.0",
    "tar": "^7.4.3",
    "undici": "^7.28.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
